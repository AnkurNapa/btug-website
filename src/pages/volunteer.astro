---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import VolunteerCard from '../components/VolunteerCard.astro';

// Show every role. The card itself decides whether to expose a sign-up button
// based on capacity/filled state, so a closed slot can never be applied into.
const all = await getCollection('volunteer');
const roles = all.map((entry) => entry.data);

// Open roles first so the actionable opportunities lead the list.
const isOpen = (r: typeof roles[number]) =>
  !(r.filled || r.filledCount >= r.capacity);
const ordered = [
  ...roles.filter(isOpen),
  ...roles.filter((r) => !isOpen(r)),
];
---
<BaseLayout
  title="Volunteer"
  description="Help run the Bengaluru Tableau User Group. Open volunteer roles, what each involves, and how to sign up."
>
  <section class="section">
    <div class="wrap">
      <SectionHeading
        eyebrow="Build the community with us"
        title="Volunteer with BTUG"
        lead="BTUG runs entirely on volunteers. Hosting an evening, mentoring at a workshop or running our socials directly shapes how Bengaluru's data community learns and connects."
      />

      <div class="why card">
        <h2 class="why-title">Why volunteering matters</h2>
        <p>
          Every meetup, workshop and conference you have enjoyed was made
          possible by members who gave their time. Volunteering is how you grow
          your network, sharpen new skills and give back — and it is the single
          biggest reason BTUG keeps going year after year.
        </p>
      </div>

      {ordered.length > 0 ? (
        <ul class="vol-grid">
          {ordered.map((role) => (
            <li><VolunteerCard role={role} /></li>
          ))}
        </ul>
      ) : (
        <p class="empty">No open roles right now. Follow our channels — new opportunities open before every season.</p>
      )}

      <aside class="note" aria-label="About sign-ups">
        <h2 class="note-title">A note on sign-ups</h2>
        <p>
          Sign-ups go through a Google Form that collects your email. Because
          this is a static site with no backend, we cannot automatically block a
          second submission — so please sign up once per role. Organisers
          de-duplicate entries by email before confirming, and a role stops
          showing its sign-up button as soon as it is filled.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .why {
    padding: var(--space-4); margin-bottom: var(--space-6);
    display: grid; gap: 0.6rem;
    border-left: 4px solid var(--color-brand);
  }
  .why-title { font-size: var(--text-lg); }
  .why p { color: var(--color-text-muted); max-width: 64ch; }
  .vol-grid {
    list-style: none; margin: 0 0 var(--space-6); padding: 0;
    display: grid; gap: var(--space-4); grid-template-columns: 1fr;
  }
  .empty { color: var(--color-text-muted); }
  .note {
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
    display: grid; gap: 0.5rem;
  }
  .note-title { font-size: var(--text-base); font-family: var(--font-display); }
  .note p { color: var(--color-text-muted); font-size: var(--text-sm); max-width: 70ch; }
  @media (min-width: 720px) {
    .vol-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .vol-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
