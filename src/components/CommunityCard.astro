---
// CommunityCard — a member spotlight / success story.
// PRIVACY EDGE CASE: renders ONLY when optInPublished===true. This repo is
// public forever; a member who has not opted in must never appear, even if a
// story file exists. All personal fields are optional-guarded.
import type { CollectionEntry } from 'astro:content';

interface Props {
  member: CollectionEntry<'community'>['data'];
}

const { member } = Astro.props;

// Hard privacy gate. No opt-in, no render.
const isPublished = member?.optInPublished === true;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const photoSrc = member?.photo
  ? (member.photo.startsWith('http') ? member.photo : `${base}${member.photo}`)
  : undefined;
---
{isPublished && (
  <figure class="community-card card">
    {member?.quote && (
      <blockquote class="community-quote">
        <p>{member.quote}</p>
      </blockquote>
    )}
    <figcaption class="community-person">
      {photoSrc ? (
        <img
          class="community-photo"
          src={photoSrc}
          alt={`Photo of ${member.memberName}`}
          width="56"
          height="56"
          loading="lazy"
        />
      ) : (
        <div class="community-photo community-photo--placeholder" aria-hidden="true">
          {member?.memberName?.charAt(0) ?? '?'}
        </div>
      )}
      <div class="community-id">
        <p class="community-name">{member.memberName}</p>
        {member?.role && <p class="community-role">{member.role}</p>}
        {member?.linkedin && (
          <a class="community-link" href={member.linkedin} target="_blank" rel="noopener noreferrer">
            LinkedIn
            <span class="visually-hidden"> profile of {member.memberName} (opens in a new tab)</span>
          </a>
        )}
      </div>
    </figcaption>
  </figure>
)}

<style>
  .community-card {
    display: grid; gap: var(--space-4); padding: var(--space-4);
    align-content: start;
  }
  .community-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .community-quote { margin: 0; }
  .community-quote p {
    font-size: var(--text-lg); line-height: 1.4; color: var(--color-text);
    font-family: var(--font-display); position: relative;
  }
  .community-quote p::before {
    content: '\201C'; color: var(--color-brand); font-size: 2.4em;
    line-height: 0; position: absolute; left: -0.1em; top: 0.5em;
    opacity: 0.18;
  }
  .community-person { display: flex; gap: var(--space-3); align-items: center; }
  .community-photo {
    width: 56px; height: 56px; border-radius: 999px; object-fit: cover;
    border: 2px solid var(--color-border); flex-shrink: 0;
  }
  .community-photo--placeholder {
    display: grid; place-items: center; background: var(--color-brand-soft);
    color: var(--color-brand-strong); font-family: var(--font-display);
    font-weight: 700; text-transform: uppercase;
  }
  .community-name { font-weight: 600; }
  .community-role { font-size: var(--text-sm); color: var(--color-text-muted); }
  .community-link { font-size: var(--text-sm); font-weight: 600; }
</style>
