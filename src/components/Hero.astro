---
import site from '../data/site.yaml';
import AnimatedBackground from './AnimatedBackground.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const joinHref = site.forms?.newsletter || `${base}/contact`;
const eventsHref = `${base}/events`;
---
<section class="hero" aria-labelledby="hero-heading">
  <AnimatedBackground />
  <div class="wrap hero-inner">
    <p class="eyebrow">Bengaluru Tableau User Group</p>
    <h1 id="hero-heading">Empowering Bengaluru's Data Community</h1>
    <p class="lead hero-lead">
      Workshops, meetups, hackathons and our flagship conference — a place for
      Bengaluru's analysts, BI developers and data enthusiasts to learn, share
      and grow with Tableau and modern analytics.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href={joinHref}>Join BTUG</a>
      <a class="btn btn-secondary" href={eventsHref}>Upcoming Events</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    background: var(--gradient-hero);
    overflow: hidden;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-4);
    padding-block: clamp(4rem, 3rem + 8vw, 9rem);
    max-width: 40ch;
  }
  .hero h1 {
    font-size: var(--text-hero);
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lead { max-width: 52ch; font-size: var(--text-lg); }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: var(--space-2); }

  @media (min-width: 720px) {
    .hero-inner { max-width: 56ch; }
  }
</style>
