---
// Top announcement ticker — grid-paper marquee (VizChitra-inspired).
import site from '../data/site.yaml';
const msg = `${site.shortName} · Bengaluru Tableau User Group · Learn · Share · Grow · Join the community →`;
const reps = Array.from({ length: 6 });
---
<div class="ticker" role="note" aria-label="Announcement">
  <div class="ticker-track">
    {reps.map(() => <span>{msg}</span>)}
  </div>
</div>

<style>
  .ticker {
    height: 34px; overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background:
      repeating-linear-gradient(0deg, transparent 0 11px, rgba(16,18,20,0.05) 11px 12px),
      repeating-linear-gradient(90deg, transparent 0 11px, rgba(16,18,20,0.05) 11px 12px),
      var(--color-surface-sunken);
    display: flex; align-items: center;
  }
  .ticker-track {
    display: inline-flex; gap: 2.2rem; white-space: nowrap;
    font-family: var(--font-mono); font-size: 0.74rem; font-weight: 600; letter-spacing: 0.05em;
    padding-left: 100%;
    animation: ticker-marquee 26s linear infinite;
  }
  .ticker-track span:nth-child(3n+1) { color: var(--color-gold); }
  .ticker-track span:nth-child(3n+2) { color: var(--color-teal); }
  .ticker-track span:nth-child(3n+3) { color: var(--color-blue); }
  @keyframes ticker-marquee { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .ticker-track { animation: none; } }
</style>
